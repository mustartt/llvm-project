## Test basic linear and graph-based pattern matching.

# REQUIRES: system-linux

# RUN: split-file %s %t
# RUN: llvm-mc -filetype=obj -triple aarch64-unknown-unknown %t/test.s -o %t.o
# RUN: %clang %cflags %t.o -o %t.exe -Wl,-q -static

## Linear pattern: match all ret instructions.
# RUN: llvm-match --pattern %t/ret.pat %t.exe 2>&1 | FileCheck %s --check-prefix=RET
# RET: Total matches: 4

## Graph pattern: adrp + add with shared capture.
# RUN: llvm-match --pattern %t/adrp_add.pat %t.exe 2>&1 \
# RUN:   | FileCheck %s --check-prefix=ADRP
# ADRP: Using graph-based matcher
# ADRP: Total matches: 2

## Graph pattern: ldrb + and with shared capture.
# RUN: llvm-match --pattern %t/ldrb_and.pat %t.exe 2>&1 \
# RUN:   | FileCheck %s --check-prefix=LDRB
# LDRB: Total matches: 2

## Pattern with no matches should report 0.
# RUN: llvm-match --pattern %t/nomatch.pat %t.exe 2>&1 \
# RUN:   | FileCheck %s --check-prefix=NOMATCH
# NOMATCH: Total matches: 0

#--- test.s
  .text
  .globl adrp_add_func
  .type adrp_add_func, %function
adrp_add_func:
  .cfi_startproc
  adrp x0, adrp_add_func
  add x0, x0, :lo12:adrp_add_func
  adrp x1, ldrb_func
  add x1, x1, :lo12:ldrb_func
  ret
  .cfi_endproc
.size adrp_add_func, .-adrp_add_func

  .globl ldrb_func
  .type ldrb_func, %function
ldrb_func:
  .cfi_startproc
  ldrb w8, [x0]
  and w8, w8, #0xff
  ldrb w9, [x0, #1]
  and w0, w9, #0xff
  ret
  .cfi_endproc
.size ldrb_func, .-ldrb_func

  .globl simple_func
  .type simple_func, %function
simple_func:
  .cfi_startproc
  mov w0, #42
  add w0, w0, #1
  ret
  .cfi_endproc
.size simple_func, .-simple_func

  .globl _start
  .type _start, %function
_start:
  .cfi_startproc
  bl adrp_add_func
  bl ldrb_func
  bl simple_func
  ret
  .cfi_endproc
.size _start, .-_start

#--- ret.pat
ret

#--- adrp_add.pat
adrp %page:xreg, _
root add %addr:xreg, %page, _

#--- ldrb_and.pat
ldrb %val:wreg, _
root and _, %val, #0xff

#--- nomatch.pat
xyzzy _, _
