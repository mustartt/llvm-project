## Test YAML suite file with multiple named patterns.

# REQUIRES: system-linux

# RUN: split-file %s %t
# RUN: llvm-mc -filetype=obj -triple aarch64-unknown-unknown %t/test.s -o %t.o
# RUN: %clang %cflags %t.o -o %t.exe -Wl,-q -static

## Suite loading message.
# RUN: llvm-match --suite %t/suite.yaml %t.exe 2>&1 \
# RUN:   | FileCheck %s --check-prefix=SUITE
# SUITE: Loaded suite with 2 pattern(s): adrp_add ldrb_and
# SUITE: --- adrp_add ---
# SUITE: Total matches: 2
# SUITE: --- ldrb_and ---
# SUITE: Total matches: 2

## Suite with --summary shows per-function counts for each pattern.
# RUN: llvm-match --suite %t/suite.yaml --summary %t.exe 2>&1 \
# RUN:   | FileCheck %s --check-prefix=SUITE-SUMMARY
# SUITE-SUMMARY: --- adrp_add ---
# SUITE-SUMMARY: 2{{.*}}adrp_add_func
# SUITE-SUMMARY: --- ldrb_and ---
# SUITE-SUMMARY: 2{{.*}}ldrb_func

## Suite and --pattern can be used together.
# RUN: llvm-match --suite %t/suite.yaml --pattern %t/ret.pat %t.exe 2>&1 \
# RUN:   | FileCheck %s --check-prefix=BOTH
# BOTH: Total matches: 4
# BOTH: --- adrp_add ---
# BOTH: --- ldrb_and ---

#--- test.s
  .text
  .globl adrp_add_func
  .type adrp_add_func, %function
adrp_add_func:
  .cfi_startproc
  adrp x0, adrp_add_func
  add x0, x0, :lo12:adrp_add_func
  adrp x1, ldrb_func
  add x1, x1, :lo12:ldrb_func
  ret
  .cfi_endproc
.size adrp_add_func, .-adrp_add_func

  .globl ldrb_func
  .type ldrb_func, %function
ldrb_func:
  .cfi_startproc
  ldrb w8, [x0]
  and w8, w8, #0xff
  ldrb w9, [x0, #1]
  and w0, w9, #0xff
  ret
  .cfi_endproc
.size ldrb_func, .-ldrb_func

  .globl simple_func
  .type simple_func, %function
simple_func:
  .cfi_startproc
  mov w0, #0
  ret
  .cfi_endproc
.size simple_func, .-simple_func

  .globl _start
  .type _start, %function
_start:
  .cfi_startproc
  bl adrp_add_func
  bl ldrb_func
  bl simple_func
  ret
  .cfi_endproc
.size _start, .-_start

#--- suite.yaml
adrp_add:
  pattern: |
    adrp %page:xreg, _
    root add %addr:xreg, %page, _

ldrb_and:
  pattern: |
    ldrb %val:wreg, _
    root and _, %val, #0xff

#--- ret.pat
ret
